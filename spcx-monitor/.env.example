# --- Tier A: required ---
# Polygon.io real-time stocks plan (https://polygon.io/pricing)
POLYGON_API_KEY=

# --- Tier B: optional — enables FULL mode (L2/L3 depth) ---
# Databento with a live Nasdaq TotalView-ITCH license (https://databento.com/datasets/XNAS.ITCH)
DATABENTO_API_KEY=

# --- Symbol / session ---
SPCX_SYMBOL=SPCX
IPO_REF_PRICE=135
SPCX_DB=data/spcx.db

# --- Alert tuning (defaults shown) ---
ALERT_THRESHOLD=0.65
CANDLE_THRESHOLD=0.7
BOOK_THRESHOLD=0.7
SIGNAL_COOLDOWN_SEC=120

# --- Twilio SMS (optional; all four required to send) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+1XXXXXXXXXX
